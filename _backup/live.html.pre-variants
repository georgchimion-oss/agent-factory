<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#08080A">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Agent Factory — Live</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --bg: #08080A;
            --surface: #111115;
            --border: #1E1E26;
            --warm: #F0845C;
            --teal: #00D2C8;
            --green: #10B981;
            --indigo: #6366F1;
            --pm: #4A9EFF;
            --coder: #10B981;
            --reviewer: #8B5CF6;
            --deployer: #F0845C;
            --text: #E8E8F0;
            --text-muted: #6B6B80;
            --header-h: 56px;
            --agent-strip-h: 104px;
            --conn-bar-h: 40px;
        }

        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 16px;
            -webkit-font-smoothing: antialiased;
        }

        /* ===================== LAYOUT ===================== */

        .app {
            display: flex;
            flex-direction: column;
            height: 100%;
            height: 100dvh;
            padding-top: env(safe-area-inset-top);
            padding-bottom: env(safe-area-inset-bottom);
            padding-left: env(safe-area-inset-left);
            padding-right: env(safe-area-inset-right);
        }

        /* ===================== HEADER ===================== */

        .header {
            flex-shrink: 0;
            height: var(--header-h);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            position: relative;
            z-index: 10;
        }

        .header-left {
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

        .logo {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 18px;
            color: #fff;
            line-height: 1;
        }

        .logo-accent {
            color: var(--warm);
        }

        .build-timer {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
            height: 14px;
            transition: color 0.3s;
        }

        .build-timer.running {
            color: var(--warm);
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.03);
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            transition: color 0.4s, background 0.4s, border-color 0.4s;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--text-muted);
            flex-shrink: 0;
            transition: background 0.4s;
        }

        .status-badge.live { color: var(--green); background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.25); }
        .status-badge.live .status-dot { background: var(--green); animation: pulse-green 1.5s ease-in-out infinite; }

        .status-badge.building { color: var(--warm); background: rgba(240,132,92,0.08); border-color: rgba(240,132,92,0.25); }
        .status-badge.building .status-dot { background: var(--warm); animation: pulse-orange 1s ease-in-out infinite; }

        .status-badge.complete { color: var(--green); background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.25); }
        .status-badge.complete .status-dot { background: var(--green); }

        @keyframes pulse-green {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16,185,129,0.5); }
            50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(16,185,129,0); }
        }

        @keyframes pulse-orange {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(240,132,92,0.5); }
            50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(240,132,92,0); }
        }

        /* ===================== AGENT STRIP ===================== */

        .agent-strip-wrap {
            flex-shrink: 0;
            height: var(--agent-strip-h);
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

        .agent-strip-wrap::-webkit-scrollbar { display: none; }

        .agent-strip {
            display: flex;
            gap: 10px;
            padding: 12px 16px;
            width: max-content;
            height: 100%;
            align-items: center;
        }

        .agent-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 10px 8px;
            width: 80px;
            border-radius: 10px;
            border: 2px solid var(--border);
            background: transparent;
            transition: border-color 0.4s, background 0.4s, box-shadow 0.4s;
            flex-shrink: 0;
        }

        .agent-card.idle {
            border-color: var(--border);
            background: transparent;
        }

        .agent-card.working {
            border-color: var(--agent-color);
            background: rgba(var(--agent-color-rgb), 0.06);
            box-shadow: 0 0 12px rgba(var(--agent-color-rgb), 0.15);
            animation: card-pulse 2s ease-in-out infinite;
        }

        .agent-card.done {
            border-color: var(--agent-color);
            background: rgba(var(--agent-color-rgb), 0.04);
        }

        @keyframes card-pulse {
            0%, 100% { box-shadow: 0 0 10px rgba(var(--agent-color-rgb), 0.15); }
            50% { box-shadow: 0 0 20px rgba(var(--agent-color-rgb), 0.3); }
        }

        .agent-card[data-agent="pm"]       { --agent-color: #4A9EFF; --agent-color-rgb: 74,158,255; }
        .agent-card[data-agent="coder"]    { --agent-color: #10B981; --agent-color-rgb: 16,185,129; }
        .agent-card[data-agent="reviewer"] { --agent-color: #8B5CF6; --agent-color-rgb: 139,92,246; }
        .agent-card[data-agent="deployer"] { --agent-color: #F0845C; --agent-color-rgb: 240,132,92; }

        .agent-emoji {
            font-size: 24px;
            line-height: 1;
            transition: filter 0.4s;
        }

        .agent-card.idle .agent-emoji {
            filter: grayscale(0.5) brightness(0.7);
        }

        .agent-card-name {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 12px;
            color: var(--agent-color);
            text-align: center;
            opacity: 0.7;
            transition: opacity 0.4s;
        }

        .agent-card.working .agent-card-name,
        .agent-card.done .agent-card-name {
            opacity: 1;
        }

        .agent-card.idle .agent-card-name {
            color: var(--text-muted);
        }

        .agent-card-status {
            font-size: 11px;
            color: var(--text-muted);
            text-align: center;
            line-height: 1.2;
            min-height: 13px;
        }

        .agent-card.working .agent-card-status {
            color: var(--agent-color);
        }

        .agent-card.done .agent-card-status {
            color: var(--green);
        }

        /* ===================== FEED ===================== */

        .feed-wrap {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch;
            padding: 12px 0 8px;
            scroll-behavior: smooth;
        }

        .feed-wrap::-webkit-scrollbar { display: none; }
        .feed-wrap { scrollbar-width: none; }

        .feed-inner {
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 0 12px;
        }

        /* Message bubble */
        .msg-bubble {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 4px 0;
            animation: slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @keyframes slide-in {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .msg-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .msg-body {
            flex: 1;
            min-width: 0;
        }

        .msg-header {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 2px;
        }

        .msg-name {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
            font-size: 13px;
        }

        .msg-time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
            flex-shrink: 0;
        }

        .msg-text {
            font-size: 15px;
            line-height: 1.5;
            color: #C8C8D8;
            word-break: break-word;
        }

        .msg-text a {
            color: var(--teal);
            text-decoration: none;
        }

        /* System message */
        .msg-system {
            text-align: center;
            padding: 8px 12px;
            animation: slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        .msg-system-inner {
            display: inline-block;
            font-size: 13px;
            color: var(--text-muted);
            padding: 4px 12px;
            border-radius: 20px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
        }

        /* Build separator */
        .build-separator {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 0 8px;
            animation: slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        .build-separator-line {
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .build-separator-text {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            flex-shrink: 0;
        }

        /* Heartbeat */
        .msg-heartbeat {
            text-align: center;
            padding: 6px 0;
            animation: slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        .msg-heartbeat-text {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: rgba(107,107,128,0.5);
            letter-spacing: 0.5px;
        }

        /* ===================== RESULT CARD ===================== */

        .result-card-wrap {
            flex-shrink: 0;
            padding: 0 12px 8px;
            display: none;
            animation: slide-up 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        .result-card-wrap.visible {
            display: block;
        }

        @keyframes slide-up {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .result-card {
            background: var(--surface);
            border: 1px solid rgba(16,185,129,0.25);
            border-radius: 14px;
            padding: 16px;
            box-shadow: 0 0 24px rgba(16,185,129,0.08);
            transition: box-shadow 0.4s;
        }

        .result-card.celebrating {
            box-shadow: 0 0 40px rgba(16,185,129,0.25);
            animation: celebrate-pulse 0.6s ease-in-out 3;
        }

        @keyframes celebrate-pulse {
            0%, 100% { box-shadow: 0 0 24px rgba(16,185,129,0.15); }
            50% { box-shadow: 0 0 50px rgba(16,185,129,0.4); }
        }

        .result-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }

        .result-time {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .result-time-label {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .result-score {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 3px;
        }

        .result-score-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--green);
            line-height: 1;
        }

        .result-score-label {
            font-size: 12px;
            color: var(--text-muted);
        }

        .result-stars {
            display: flex;
            gap: 2px;
            font-size: 14px;
        }

        .btn-open-site {
            display: block;
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(0,210,200,0.1));
            border: 1px solid rgba(16,185,129,0.3);
            border-radius: 10px;
            text-align: center;
            color: var(--green);
            font-family: 'Space Grotesk', sans-serif;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
            -webkit-tap-highlight-color: transparent;
        }

        .btn-open-site:active {
            background: rgba(16,185,129,0.2);
        }

        .btn-open-site-disabled {
            opacity: 0.4;
            pointer-events: none;
        }

        /* ===================== CONNECTION BAR ===================== */

        .conn-bar {
            flex-shrink: 0;
            height: var(--conn-bar-h);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-top: 1px solid var(--border);
            background: var(--surface);
            padding: 0 16px;
        }

        .conn-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--text-muted);
            flex-shrink: 0;
            transition: background 0.3s;
        }

        .conn-dot.connected { background: var(--green); }
        .conn-dot.reconnecting { background: var(--warm); animation: pulse-orange 1s ease-in-out infinite; }
        .conn-dot.error { background: #EF4444; }

        .conn-text {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .conn-spinner {
            width: 12px;
            height: 12px;
            border: 2px solid var(--border);
            border-top-color: var(--warm);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            display: none;
        }

        .conn-spinner.visible { display: block; }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ===================== EMPTY STATE ===================== */

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 32px;
            text-align: center;
            gap: 12px;
            opacity: 0.5;
        }

        .empty-state-icon {
            font-size: 40px;
        }

        .empty-state-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 16px;
            color: var(--text-muted);
        }

        .empty-state-sub {
            font-size: 14px;
            color: var(--text-muted);
            opacity: 0.7;
        }
    </style>
</head>
<body>
<div class="app">

    <!-- HEADER -->
    <header class="header">
        <div class="header-left">
            <div class="logo">Agent <span class="logo-accent">Factory</span></div>
            <div class="build-timer" id="build-timer">&nbsp;</div>
        </div>
        <div class="status-badge" id="status-badge">
            <div class="status-dot"></div>
            <span id="status-text">IDLE</span>
        </div>
    </header>

    <!-- AGENT STRIP -->
    <div class="agent-strip-wrap">
        <div class="agent-strip">
            <div class="agent-card idle" id="agent-pm" data-agent="pm">
                <div class="agent-emoji">📋</div>
                <div class="agent-card-name">PM</div>
                <div class="agent-card-status" id="status-pm">Ready</div>
            </div>
            <div class="agent-card idle" id="agent-coder" data-agent="coder">
                <div class="agent-emoji">💻</div>
                <div class="agent-card-name">Coder</div>
                <div class="agent-card-status" id="status-coder">Ready</div>
            </div>
            <div class="agent-card idle" id="agent-reviewer" data-agent="reviewer">
                <div class="agent-emoji">🔍</div>
                <div class="agent-card-name">Reviewer</div>
                <div class="agent-card-status" id="status-reviewer">Ready</div>
            </div>
            <div class="agent-card idle" id="agent-deployer" data-agent="deployer">
                <div class="agent-emoji">🚀</div>
                <div class="agent-card-name">Deployer</div>
                <div class="agent-card-status" id="status-deployer">Ready</div>
            </div>
        </div>
    </div>

    <!-- LIVE FEED -->
    <div class="feed-wrap" id="feed-wrap">
        <div class="feed-inner" id="feed">
            <div class="empty-state" id="empty-state">
                <div class="empty-state-icon">⚙</div>
                <div class="empty-state-text">Waiting for build to start</div>
                <div class="empty-state-sub">Messages will appear here in real time</div>
            </div>
        </div>
    </div>

    <!-- RESULT CARD -->
    <div class="result-card-wrap" id="result-card-wrap">
        <div class="result-card" id="result-card">
            <div class="result-top">
                <div>
                    <div class="result-time" id="result-time">—</div>
                    <div class="result-time-label">Build time</div>
                </div>
                <div class="result-score" id="result-score-wrap" style="display:none">
                    <div class="result-score-value" id="result-score">—</div>
                    <div class="result-score-label">Review score</div>
                    <div class="result-stars" id="result-stars"></div>
                </div>
            </div>
            <a id="btn-open-site" class="btn-open-site btn-open-site-disabled" href="#" target="_blank" rel="noopener">
                Open Live Site →
            </a>
        </div>
    </div>

    <!-- CONNECTION BAR -->
    <div class="conn-bar">
        <div class="conn-dot" id="conn-dot"></div>
        <div class="conn-spinner" id="conn-spinner"></div>
        <div class="conn-text" id="conn-text">Connecting...</div>
    </div>

</div>

<script>
    // ===================== CONFIG =====================
    const AGENTS = {
        pm:       { name: 'Plan',    color: '#4A9EFF', emoji: '📋' },
        coder:    { name: 'Code',    color: '#10B981', emoji: '💻' },
        reviewer: { name: 'Review',  color: '#8B5CF6', emoji: '🔍' },
        deployer: { name: 'Deploy',  color: '#F0845C', emoji: '🚀' },
    };

    // ===================== STATE =====================
    let es = null;
    let reconnectDelay = 3000;
    let reconnectTimer = null;
    let buildStartTime = null;
    let timerInterval = null;
    let spectatorCount = null;
    let reviewScore = null;
    let currentSiteUrl = null;
    let feedHasContent = false;

    // ===================== SSE =====================
    function connect() {
        if (es) {
            es.close();
            es = null;
        }

        setConnState('connecting');

        es = new EventSource('/factory/api/live-stream');

        es.onopen = () => {
            reconnectDelay = 3000;
            clearTimeout(reconnectTimer);
        };

        es.onmessage = (e) => {
            try {
                const evt = JSON.parse(e.data);
                handleEvent(evt);
            } catch (err) {
                // malformed event — ignore
            }
        };

        es.onerror = () => {
            setConnState('reconnecting');
            es.close();
            es = null;
            scheduleReconnect();
        };
    }

    function scheduleReconnect() {
        clearTimeout(reconnectTimer);
        reconnectTimer = setTimeout(() => {
            connect();
        }, reconnectDelay);
        reconnectDelay = Math.min(reconnectDelay * 1.5, 30000);
    }

    // ===================== EVENT HANDLER =====================
    function handleEvent(evt) {
        switch (evt.type) {
            case 'connected':
                setConnState('connected');
                if (evt.spectatorCount != null) updateSpectatorCount(evt.spectatorCount);
                break;

            case 'build_started':
                clearFeed();
                hideResultCard();
                resetAgents();
                setStatus('building');
                startTimer();
                reviewScore = null;
                currentSiteUrl = null;
                addSeparator(evt.modify ? 'Modifying build' : 'New build started');
                break;

            case 'agent_status':
                updateAgentCard(evt.agent, evt.status, evt.message);
                if (evt.message) {
                    addBubble(evt.agent, evt.message);
                }
                break;

            case 'chat_message':
                addBubble(evt.agent, evt.message);
                break;

            case 'review_result':
                reviewScore = evt.score;
                if (evt.score != null) {
                    updateResultScore(evt.score);
                }
                addBubble('reviewer', 'Review score: ' + evt.score + '/10 — ' + (evt.passed ? 'Passed ✓' : 'Needs revision'));
                break;

            case 'build_complete':
                stopTimer();
                currentSiteUrl = evt.siteUrl || null;
                showResultCard(evt);
                setStatus('complete');
                break;

            case 'celebrate':
                setStatus('complete');
                celebrateResultCard();
                break;

            case 'heartbeat':
                addHeartbeat();
                break;

            case 'spectator_count':
                if (evt.count != null) updateSpectatorCount(evt.count);
                break;

            case 'error':
                addSystemMsg('Error: ' + (evt.message || 'Unknown error'));
                setStatus('idle');
                stopTimer();
                break;
        }
    }

    // ===================== FEED =====================
    function clearFeed() {
        const feed = document.getElementById('feed');
        feed.innerHTML = '';
        feedHasContent = false;
        document.getElementById('empty-state') && removeEmptyState();
    }

    function removeEmptyState() {
        const el = document.getElementById('empty-state');
        if (el) el.remove();
    }

    function ensureNoEmptyState() {
        if (!feedHasContent) {
            feedHasContent = true;
            removeEmptyState();
        }
    }

    function addBubble(agentId, text) {
        ensureNoEmptyState();
        const feed = document.getElementById('feed');
        const agent = AGENTS[agentId];

        const wrapper = document.createElement('div');
        wrapper.className = 'msg-bubble';

        if (agent) {
            const avatar = document.createElement('div');
            avatar.className = 'msg-avatar';
            avatar.style.background = hexToRgba(agent.color, 0.15);
            avatar.textContent = agent.emoji;

            const body = document.createElement('div');
            body.className = 'msg-body';

            const header = document.createElement('div');
            header.className = 'msg-header';

            const name = document.createElement('span');
            name.className = 'msg-name';
            name.style.color = agent.color;
            name.textContent = agent.name;

            const time = document.createElement('span');
            time.className = 'msg-time';
            time.textContent = formatTime(new Date());

            header.appendChild(name);
            header.appendChild(time);

            const msgText = document.createElement('div');
            msgText.className = 'msg-text';
            msgText.textContent = text;

            body.appendChild(header);
            body.appendChild(msgText);

            wrapper.appendChild(avatar);
            wrapper.appendChild(body);
        } else {
            // fallback for unknown agents
            wrapper.innerHTML = '<div class="msg-system"><div class="msg-system-inner">' + escapeHtml(text) + '</div></div>';
        }

        feed.appendChild(wrapper);
        scrollFeedToBottom();
    }

    function addSystemMsg(text) {
        ensureNoEmptyState();
        const feed = document.getElementById('feed');
        const el = document.createElement('div');
        el.className = 'msg-system';
        el.innerHTML = '<div class="msg-system-inner">' + escapeHtml(text) + '</div>';
        feed.appendChild(el);
        scrollFeedToBottom();
    }

    function addSeparator(label) {
        ensureNoEmptyState();
        const feed = document.getElementById('feed');
        const el = document.createElement('div');
        el.className = 'build-separator';
        el.innerHTML =
            '<div class="build-separator-line"></div>' +
            '<div class="build-separator-text">' + escapeHtml(label) + '</div>' +
            '<div class="build-separator-line"></div>';
        feed.appendChild(el);
        scrollFeedToBottom();
    }

    function addHeartbeat() {
        const feed = document.getElementById('feed');
        const el = document.createElement('div');
        el.className = 'msg-heartbeat';
        el.innerHTML = '<span class="msg-heartbeat-text">· · · still working</span>';
        feed.appendChild(el);
        scrollFeedToBottom();
    }

    function scrollFeedToBottom() {
        const wrap = document.getElementById('feed-wrap');
        wrap.scrollTop = wrap.scrollHeight;
    }

    // ===================== AGENT CARDS =====================
    function updateAgentCard(agentId, status, message) {
        const card = document.getElementById('agent-' + agentId);
        const statusEl = document.getElementById('status-' + agentId);
        if (!card) return;

        card.classList.remove('idle', 'working', 'done');

        if (status === 'working') {
            card.classList.add('working');
            if (statusEl) statusEl.textContent = message ? truncate(message, 14) : 'Working...';
        } else if (status === 'done' || status === 'idle') {
            card.classList.add(status === 'done' ? 'done' : 'idle');
            if (statusEl) statusEl.textContent = status === 'done' ? '✓ Done' : 'Ready';
        } else {
            card.classList.add('idle');
            if (statusEl) statusEl.textContent = 'Ready';
        }
    }

    function resetAgents() {
        ['pm', 'coder', 'reviewer', 'deployer'].forEach(id => {
            updateAgentCard(id, 'idle', null);
        });
    }

    // ===================== STATUS BADGE =====================
    function setStatus(state) {
        const badge = document.getElementById('status-badge');
        const text = document.getElementById('status-text');
        badge.className = 'status-badge';

        switch (state) {
            case 'live':
                badge.classList.add('live');
                text.textContent = 'LIVE';
                break;
            case 'building':
                badge.classList.add('building');
                text.textContent = 'BUILDING';
                break;
            case 'complete':
                badge.classList.add('complete');
                text.textContent = 'COMPLETE';
                break;
            case 'idle':
            default:
                text.textContent = 'IDLE';
                break;
        }
    }

    // ===================== TIMER =====================
    function startTimer() {
        stopTimer();
        buildStartTime = Date.now();
        const el = document.getElementById('build-timer');
        el.classList.add('running');

        timerInterval = setInterval(() => {
            const elapsed = Math.floor((Date.now() - buildStartTime) / 1000);
            el.textContent = formatElapsed(elapsed);
        }, 1000);

        el.textContent = '0:00';
    }

    function stopTimer() {
        if (timerInterval) {
            clearInterval(timerInterval);
            timerInterval = null;
        }
        const el = document.getElementById('build-timer');
        el.classList.remove('running');
    }

    function formatElapsed(totalSeconds) {
        const m = Math.floor(totalSeconds / 60);
        const s = totalSeconds % 60;
        return m + ':' + String(s).padStart(2, '0');
    }

    // ===================== RESULT CARD =====================
    function showResultCard(evt) {
        const wrap = document.getElementById('result-card-wrap');
        const timeEl = document.getElementById('result-time');
        const btn = document.getElementById('btn-open-site');

        // Compute elapsed time
        let elapsedText = '—';
        if (buildStartTime) {
            const elapsed = Math.floor((Date.now() - buildStartTime) / 1000);
            const m = Math.floor(elapsed / 60);
            const s = elapsed % 60;
            elapsedText = m > 0 ? m + 'm ' + s + 's' : s + 's';
            // Also update the timer display to final value
            document.getElementById('build-timer').textContent = formatElapsed(elapsed);
        }
        timeEl.textContent = elapsedText;

        // Score
        if (reviewScore != null) {
            updateResultScore(reviewScore);
        }

        // Button
        if (evt.siteUrl) {
            btn.href = evt.siteUrl;
            btn.classList.remove('btn-open-site-disabled');
            btn.textContent = 'Open Live Site →';
        } else {
            btn.classList.add('btn-open-site-disabled');
            btn.textContent = 'Site not yet available';
        }

        // Remove and re-add to re-trigger animation
        wrap.classList.remove('visible');
        void wrap.offsetWidth; // force reflow
        wrap.classList.add('visible');
    }

    function updateResultScore(score) {
        const scoreWrap = document.getElementById('result-score-wrap');
        const scoreEl = document.getElementById('result-score');
        const starsEl = document.getElementById('result-stars');

        scoreEl.textContent = score + '/10';
        scoreWrap.style.display = 'flex';

        // Stars (5-star scale, score/10 * 5)
        const starCount = Math.round((score / 10) * 5);
        let starsHtml = '';
        for (let i = 1; i <= 5; i++) {
            starsHtml += '<span style="color:' + (i <= starCount ? '#F59E0B' : '#333') + '">★</span>';
        }
        starsEl.innerHTML = starsHtml;
    }

    function hideResultCard() {
        document.getElementById('result-card-wrap').classList.remove('visible');
        document.getElementById('result-score-wrap').style.display = 'none';
        document.getElementById('result-score').textContent = '—';
        document.getElementById('result-stars').innerHTML = '';
        document.getElementById('result-time').textContent = '—';
        const btn = document.getElementById('btn-open-site');
        btn.href = '#';
        btn.classList.add('btn-open-site-disabled');
        btn.textContent = 'Open Live Site →';
    }

    function celebrateResultCard() {
        const card = document.getElementById('result-card');
        card.classList.remove('celebrating');
        void card.offsetWidth;
        card.classList.add('celebrating');
        setTimeout(() => card.classList.remove('celebrating'), 2000);
    }

    // ===================== CONNECTION BAR =====================
    function setConnState(state) {
        const dot = document.getElementById('conn-dot');
        const spinner = document.getElementById('conn-spinner');
        const text = document.getElementById('conn-text');

        dot.className = 'conn-dot';
        spinner.classList.remove('visible');

        switch (state) {
            case 'connected':
                dot.classList.add('connected');
                setStatus('live');
                text.textContent = spectatorCount != null
                    ? 'Connected — ' + spectatorCount + ' watching'
                    : 'Connected';
                break;
            case 'reconnecting':
                dot.classList.add('reconnecting');
                spinner.classList.add('visible');
                text.textContent = 'Reconnecting...';
                break;
            case 'error':
                dot.classList.add('error');
                text.textContent = 'Connection lost';
                break;
            case 'connecting':
            default:
                spinner.classList.add('visible');
                text.textContent = 'Connecting...';
                break;
        }
    }

    function updateSpectatorCount(count) {
        spectatorCount = count;
        const dot = document.getElementById('conn-dot');
        if (dot.classList.contains('connected')) {
            document.getElementById('conn-text').textContent =
                'Connected — ' + count + ' watching';
        }
    }

    // ===================== UTILS =====================
    function escapeHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function truncate(str, maxLen) {
        return str.length > maxLen ? str.slice(0, maxLen) + '…' : str;
    }

    function formatTime(date) {
        return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function hexToRgba(hex, alpha) {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
    }

    // ===================== INIT =====================
    connect();
</script>
</body>
</html>
